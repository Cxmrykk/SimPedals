module pedal_side_plate() {
    linear_extrude(height = 3.0, convexity=10) {
        difference() {
            // Main solid body
            polygon(points=outer_loop);
            
            // Subtracted interior cutouts
            polygon(points=slot1);
            polygon(points=slot2);
            polygon(points=slot3);
            
            // Subtracted drilled holes
            for (h = circular_holes) {
                translate([h[0], h[1]]) circle(r=h[2], $fn=36);
            }
        }
    }
}

