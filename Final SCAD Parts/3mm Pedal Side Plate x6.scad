/* 
   Helper function to generate points for an arc.
   c: center [x, y]
   r: radius
   a1, a2: start and end angles in degrees
   cw: if true, arc is traversed clockwise from a2 down to a1; 
       if false, counter-clockwise from a1 up to a2.
   steps: number of line segments to use for the arc.
*/
function arc_pts(c, r, a1, a2, cw=false, steps=32) =
    cw ? 
    let (
        start = a2,
        end = a1 < a2 ? a1 : a1 - 360,
        step = (end - start) / steps
    )
    [ for (i = [0:steps]) [ c[0] + r * cos(start + i * step), c[1] + r * sin(start + i * step) ] ]
    :
    let (
        start = a1,
        end = a2 > a1 ? a2 : a2 + 360,
        step = (end - start) / steps
    )
    [ for (i = [0:steps]) [ c[0] + r * cos(start + i * step), c[1] + r * sin(start + i * step) ] ];

